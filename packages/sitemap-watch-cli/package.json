{
  "name": "@deniffer/sitemap-watch-cli",
  "version": "0.1.0",
  "description": "Competitor sitemap snapshot CLI for product growth and SEO workflows.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deniffer/product-growth-tools.git",
    "directory": "packages/sitemap-watch-cli"
  },
  "bin": {
    "sitemap-watch": "./bin/sitemap-watch-cli.js",
    "sitemap-watch-cli": "./bin/sitemap-watch-cli.js"
  },
  "files": [
    "index.ts",
    "context.ts",
    "provider.ts",
    "services.ts",
    "schema.ts",
    "output.ts",
    "bin",
    "handlers",
    "lib",
    "!**/*.test.ts",
    "examples/registry.example.json",
    "index.bdd.md",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "sitemap-watch": "bun run ./index.ts",
    "cli": "bun run ./index.ts",
    "cli:schema": "bun run sitemap-watch --schema",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "test:once": "vitest run"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@valibot/to-json-schema": "^1.6.0",
    "argc": "github:ethan-huo/argc",
    "fast-xml-parser": "^5.3.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
