{
  "name": "product-growth-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.6.0",
    "@valibot/to-json-schema": "^1.6.0",
    "argc": "github:ethan-huo/argc",
    "bun-types": "^1.3.13",
      "dotenv": "^17.2.2",
      "typescript": "^5",
      "valibot": "^1.2.0",
      "vitest": "^4.0.18"
    }
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "bun-types": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "scripts": {
    "check-types": "bun run --filter '*' check-types",
    "test": "bun run --filter '*' test:once",
    "gsc": "bun run --filter @deniffer/gsc-cli cli",
    "google-ads": "bun run --filter @deniffer/google-ads-cli cli",
    "sitemap-watch": "bun run --filter @deniffer/sitemap-watch-cli cli"
  }
}
